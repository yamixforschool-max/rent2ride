# Copy this to .env for local dev (never commit .env)
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,yourdomain.com

# Render Postgres — paste the Internal Database URL from Render dashboard
DATABASE_URL=postgres://user:password@host/dbname

# PayMongo
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=

# Email (optional — remove to keep using console backend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
